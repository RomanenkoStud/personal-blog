---
import Head from '@/components/ui/Head.astro';
import ThemeInit from '@/components/ui/ThemeInit.astro';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: 'dashboard' | 'posts' | 'pages' | 'media' | 'subscribers' | 'profile';
}

const { title, activeNav } = Astro.props;
const adminEmail = Astro.locals.adminEmail ?? '';

const navItems = [
  { href: '/admin', label: 'Dashboard', key: 'dashboard' as const },
  { href: '/admin/posts', label: 'Posts', key: 'posts' as const },
  { href: '/admin/pages', label: 'Pages', key: 'pages' as const },
  { href: '/admin/media', label: 'Media', key: 'media' as const },
  { href: '/admin/subscribers', label: 'Subscribers', key: 'subscribers' as const },
  { href: '/admin/profile', label: 'Profile', key: 'profile' as const },
];
---

<html lang="en" data-theme="light">
<head>
  <Head title={`Admin · ${title}`} />
  <ThemeInit />
</head>
<body style="font-family:'Space Grotesk',sans-serif;line-height:1.6;color:var(--color-ink);background:var(--color-surface);margin:0;min-height:100vh;display:flex">

  <!-- Sidebar -->
  <aside style="width:220px;flex:none;background:var(--color-surface-alt);border-right:1px solid var(--color-border-light);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:40">
    <div style="padding:20px 18px 16px;border-bottom:1px solid var(--color-border-light)">
      <a href="/admin" style="font:600 14px 'Space Grotesk',sans-serif;color:var(--color-ink);text-decoration:none">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="20" height="20" style="vertical-align:-4px;margin-right:8px" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="#3a7d6c"/>
          <g fill="#fff">
            <path fill-rule="evenodd" d="M5.5 21V11h4c3 0 4.5 1.6 4.5 3.5S12.5 18 9.5 18H7.7V21ZM7.7 13v3h2c1.4 0 2.2-.6 2.2-1.5S11.1 13 9.7 13Z"/>
            <path fill-rule="evenodd" d="M15.5 21V11h4c3 0 4.5 1.5 4.5 3.3 0 1.4-1 2.6-2.5 3L24 21h-2.5l-2.2-3H17.7V21ZM17.7 13v2.8h2c1.4 0 2.2-.6 2.2-1.4s-.8-1.4-2.2-1.4Z"/>
            <rect x="25.5" y="9" width="2" height="14" rx="1"/>
          </g>
        </svg>
        Admin
      </a>
    </div>

    <nav style="flex:1;padding:12px 0">
      {navItems.map(item => (
        <a
          href={item.href}
          style={`display:block;padding:9px 18px;font:400 13px 'Space Grotesk',sans-serif;text-decoration:none;color:${activeNav === item.key ? 'var(--color-accent)' : 'var(--color-meta)'};border-left:3px solid ${activeNav === item.key ? 'var(--color-accent)' : 'transparent'};font-weight:${activeNav === item.key ? '600' : '400'}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div style="padding:14px 18px;border-top:1px solid var(--color-border-light);display:flex;flex-direction:column;gap:10px">
      <a href="/" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-dim);text-decoration:none">&larr; Back to site</a>
      <div style="display:flex;align-items:center;justify-content:space-between">
        <span style="font:400 10px 'IBM Plex Mono',monospace;color:var(--color-placeholder);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px" title={adminEmail}>{adminEmail}</span>
        <ThemeToggle />
      </div>
    </div>
  </aside>

  <!-- Main content -->
  <main style="flex:1;margin-left:220px;min-height:100vh">
    <div style="max-width:1200px;margin:0 auto;padding:32px 32px 48px">
      <slot />
    </div>
  </main>

</body>
</html>
