---
import Head from '../components/Head.astro';
import ThemeInit from '../components/ThemeInit.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { NAV_LINKS } from '../consts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedAt?: string;
}

const { title, description, ogImage, ogType, publishedAt } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en" data-theme="light">
<head>
  <Head title={title} description={description} ogImage={ogImage} ogType={ogType} publishedAt={publishedAt} />
  <ThemeInit />
</head>
<body style="font-family:'Space Grotesk',sans-serif;line-height:1.6;color:var(--color-ink,#1a1c2e);background:var(--color-surface,#fff);margin:0">

  <!-- ===== HEADER ===== -->
  <header style="position:sticky;top:0;z-index:50;background:var(--color-surface,#fff);border-bottom:1px solid var(--color-border-light,#eef0f4)">
    <div style="max-width:780px;margin:0 auto;display:flex;align-items:center;padding:16px 26px">

      <!-- Logo -->
      <a href="/" class="logo-link">
        <svg class="logo-mark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="24" height="24" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="#4f56e8"/>
          <g fill="#fff">
            <path fill-rule="evenodd" d="M5.5 21V11h4c3 0 4.5 1.6 4.5 3.5S12.5 18 9.5 18H7.7V21ZM7.7 13v3h2c1.4 0 2.2-.6 2.2-1.5S11.1 13 9.7 13Z"/>
            <path fill-rule="evenodd" d="M15.5 21V11h4c3 0 4.5 1.5 4.5 3.3 0 1.4-1 2.6-2.5 3L24 21h-2.5l-2.2-3H17.7V21ZM17.7 13v2.8h2c1.4 0 2.2-.6 2.2-1.4s-.8-1.4-2.2-1.4Z"/>
            <rect class="logo-cursor" x="25.5" y="9" width="2" height="14" rx="1"/>
          </g>
        </svg>
        <span class="logo-text">Pavlo Romanenko</span>
      </a>

      <!-- Nav -->
      <nav style="display:flex;gap:20px;margin-left:26px">
        {NAV_LINKS.map(link => (
          <a
            href={link.href}
            style={`font:400 12px 'IBM Plex Mono',monospace;color:${currentPath.startsWith(link.href) ? 'var(--color-ink,#1a1c2e)' : 'var(--color-meta,#6b6e7e)'};text-decoration:none`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side: search + theme toggle -->
      <div style="margin-left:auto;display:flex;align-items:center;gap:8px">
        <button id="search-trigger" aria-label="Open search">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span class="search-label">search…</span>
          <kbd>⌘K</kbd>
        </button>
        <search-modal></search-modal>
        <ThemeToggle />
      </div>
    </div>
  </header>

  <!-- ===== MAIN ===== -->
  <main>
    <slot />
  </main>

  <!-- ===== FOOTER ===== -->
  <footer style="border-top:1px solid var(--color-border-light,#eef0f4);margin-top:60px">
    <div style="max-width:780px;margin:0 auto;padding:24px 26px;display:flex;align-items:center;justify-content:space-between">
      <div style="display:inline-flex;align-items:center;gap:0;font:500 13px 'IBM Plex Mono',monospace">
        <span style="color:var(--color-periwinkle,#7c81f2)">pavlo@romanenko.com</span><span style="color:var(--color-dim,#9a9dab)">:~$</span>
        <span style="display:inline-block;width:8px;height:17px;background:#4f56e8;border-radius:1px;margin-left:4px;animation:blink 1.1s step-end infinite"></span>
      </div>
      <span style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-dim,#9a9dab)">
        &copy; {new Date().getFullYear()} Pavlo Romanenko
      </span>
    </div>
  </footer>

<script>
  import '../components/SearchModal';
</script>
</body>
</html>

<style>
  .logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .logo-text {
    font: 600 15px 'Space Grotesk', sans-serif;
    color: var(--color-ink, #1a1c2e);
  }
  .logo-cursor {
    animation: cursor-blink 1.1s step-end infinite;
  }
  .logo-link:hover .logo-mark {
    animation: logo-bounce 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @keyframes logo-bounce {
    0% { transform: scale(1) rotate(0deg); }
    40% { transform: scale(1.15) rotate(-4deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  #search-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-alt);
    border-radius: 7px;
    padding: 0 11px;
    cursor: pointer;
    font: 400 12px 'IBM Plex Mono', monospace;
    color: var(--color-placeholder);
    transition: border-color 0.15s;
  }
  #search-trigger:hover {
    border-color: var(--color-indigo);
  }
  #search-trigger kbd {
    font: 400 10px 'IBM Plex Mono', monospace;
    color: var(--color-border);
    border: 1px solid var(--color-border-light);
    border-radius: 4px;
    padding: 1px 5px;
    line-height: 1;
  }
  @media (max-width: 640px) {
    .search-label { display: none; }
    #search-trigger kbd { display: none; }
  }
</style>
