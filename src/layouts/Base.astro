---
import Head from '@/components/ui/Head.astro';
import ThemeInit from '@/components/ui/ThemeInit.astro';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import { NAV_LINKS, SITE_TITLE } from '@/config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedAt?: string;
  articleTag?: string;
  author?: string;
  noIndex?: boolean;
}

const { title, description, ogImage, ogType, publishedAt, articleTag, author, noIndex } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en" data-theme="light">
<head>
  <Head title={title} description={description} ogImage={ogImage} ogType={ogType} publishedAt={publishedAt} articleTag={articleTag} author={author} noIndex={noIndex} />
  <ThemeInit />
</head>
<body>

  <!-- ===== HEADER ===== -->
  <header class="sticky top-0 z-50 bg-surface border-b border-border-light">
    <div class="page-container flex items-center px-[26px] py-4 max-sm:px-4 max-sm:py-3">

      <!-- Logo -->
      <a href="/" class="group/logo flex items-center gap-2.5 no-underline text-inherit hover:text-inherit shrink-0">
        <svg class="group-hover/logo:animate-logo-bounce" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="24" height="24" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="#4f56e8"/>
          <g fill="#fff">
            <path fill-rule="evenodd" d="M5.5 21V11h4c3 0 4.5 1.6 4.5 3.5S12.5 18 9.5 18H7.7V21ZM7.7 13v3h2c1.4 0 2.2-.6 2.2-1.5S11.1 13 9.7 13Z"/>
            <path fill-rule="evenodd" d="M15.5 21V11h4c3 0 4.5 1.5 4.5 3.3 0 1.4-1 2.6-2.5 3L24 21h-2.5l-2.2-3H17.7V21ZM17.7 13v2.8h2c1.4 0 2.2-.6 2.2-1.4s-.8-1.4-2.2-1.4Z"/>
            <rect class="animate-cursor-blink" x="25.5" y="9" width="2" height="14" rx="1"/>
          </g>
        </svg>
        <span class="font-heading font-semibold text-[15px] text-ink max-sm:text-sm">{SITE_TITLE}</span>
      </a>

      <!-- Desktop nav -->
      <nav class="flex gap-5 ml-[26px] max-sm:hidden">
        {NAV_LINKS.map(link => (
          <a
            href={link.href}
            class:list={[
              'font-mono text-xs no-underline hover:text-indigo',
              currentPath.startsWith(link.href) ? 'text-ink' : 'text-meta'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="ml-auto flex items-center gap-2">
        <button id="search-trigger" class="search-trigger" aria-label="Open search">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span class="max-sm:hidden">search…</span>
          <kbd>⌘K</kbd>
        </button>
        <search-modal></search-modal>
        <ThemeToggle />
        <button id="menu-toggle" class="hidden max-sm:flex size-8 items-center justify-center border-none bg-transparent text-ink cursor-pointer rounded-md p-0 hover:bg-mist group" aria-label="Open menu" aria-expanded="false">
          <svg class="group-aria-expanded:hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="hidden group-aria-expanded:block" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav drawer -->
    <nav id="mobile-nav" class="hidden data-[open]:flex flex-col page-container px-[26px] pb-3 border-t border-border-light max-sm:px-4 max-sm:pb-2">
      {NAV_LINKS.map(link => (
        <a
          href={link.href}
          class:list={[
            'flex items-center justify-between py-3.5 px-1 font-heading text-sm no-underline border-b border-border-light last:border-0 hover:text-indigo',
            currentPath.startsWith(link.href) ? 'text-ink font-medium' : 'text-meta'
          ]}
        >
          {link.label}
          <svg class="text-dim shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ))}
    </nav>
  </header>

  <!-- ===== MAIN ===== -->
  <main>
    <slot />
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="border-t border-border-light mt-[60px] max-sm:mt-10">
    <div class="page-container flex items-center justify-between px-[26px] py-6 max-sm:flex-col max-sm:gap-2 max-sm:px-4 max-sm:py-5">
      <div class="inline-flex items-center font-mono font-medium text-[13px] max-sm:text-[11px]">
        <span class="text-periwinkle">pavlo@romanenko.com</span><span class="text-dim">:~$</span>
        <span class="inline-block w-2 h-[17px] bg-indigo rounded-[1px] ml-1 animate-blink"></span>
      </div>
      <span class="font-mono text-[11px] text-dim">
        &copy; {new Date().getFullYear()} {SITE_TITLE}
      </span>
    </div>
  </footer>

<script>
  import '@/components/ui/SearchModal';
  import '@/components/ui/NewsletterForm';
  import '@/components/ui/window-frame';

  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileNav = document.getElementById('mobile-nav')!;

  menuToggle.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    if (!expanded) {
      mobileNav.setAttribute('data-open', '');
    } else {
      mobileNav.removeAttribute('data-open');
    }
  });

  document.addEventListener('click', (e) => {
    if (!menuToggle.contains(e.target as Node) && !mobileNav.contains(e.target as Node)) {
      menuToggle.setAttribute('aria-expanded', 'false');
      mobileNav.removeAttribute('data-open');
    }
  });
</script>
</body>
</html>
