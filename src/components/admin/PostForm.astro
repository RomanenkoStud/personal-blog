---
import type { BlogPost } from '@/types/content';
import { POST_STATUS } from '@/config';

interface Props {
  areas: string[];
  post?: BlogPost;
  action: string;
  method: 'POST' | 'PUT';
}

const { areas, post, action, method } = Astro.props;
const isEdit = !!post;
const selectedArea = post?.area ?? areas[0] ?? '';
const currentStatus = post?.status ?? POST_STATUS.DRAFT;
const isDraft = !isEdit || currentStatus === POST_STATUS.DRAFT;
const isPublished = isEdit && currentStatus === POST_STATUS.PUBLISHED;
const isArchived = isEdit && currentStatus === POST_STATUS.ARCHIVED;

const now = new Date();
const defaultDate = now.toISOString().slice(0, 16);

const ADD_NEW_SENTINEL = '__add_new__';
---

<form id="post-form" style="display:flex;flex-direction:column;gap:20px">

  <!-- Title -->
  <div>
    <label for="title" style="display:block;font:500 11px 'IBM Plex Mono',monospace;color:var(--color-meta);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em">Title</label>
    <input
      type="text"
      id="title"
      name="title"
      value={post?.title ?? ''}
      required
      style="width:100%;height:36px;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:0 10px;font:400 14px 'Space Grotesk',sans-serif;color:var(--color-ink);outline:none;box-sizing:border-box"
    />
    <div class="field-error" data-field="title" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-error);margin-top:4px;display:none"></div>
  </div>

  <!-- Slug -->
  <slug-field title={post?.title ?? ''} value={post?.slug ?? ''}></slug-field>
  <div class="field-error" data-field="slug" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-error);margin-top:-14px;display:none"></div>

  <!-- Area + Date row -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
    <div>
      <label for="area-select" style="display:block;font:500 11px 'IBM Plex Mono',monospace;color:var(--color-meta);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em">Area</label>
      <input type="hidden" id="area" name="area" value={selectedArea} />
      <select
        id="area-select"
        style="width:100%;height:36px;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:0 8px;font:400 13px 'IBM Plex Mono',monospace;color:var(--color-ink);outline:none;box-sizing:border-box"
      >
        {areas.map(area => (
          <option value={area} selected={selectedArea === area}>{area}</option>
        ))}
        <option value={ADD_NEW_SENTINEL}>+ Add new…</option>
      </select>
      <input
        type="text"
        id="area-custom"
        placeholder="new area name"
        style="display:none;width:100%;height:36px;margin-top:6px;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:0 10px;font:400 13px 'IBM Plex Mono',monospace;color:var(--color-ink);outline:none;box-sizing:border-box"
      />
      <div class="field-error" data-field="area" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-error);margin-top:4px;display:none"></div>
    </div>

    <div>
      <label for="publishedAt" style="display:block;font:500 11px 'IBM Plex Mono',monospace;color:var(--color-meta);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em">Published At</label>
      <input
        type="datetime-local"
        id="publishedAt"
        name="publishedAt"
        value={post ? post.publishedAt.slice(0, 16) : defaultDate}
        required
        style="width:100%;height:36px;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:0 8px;font:400 13px 'IBM Plex Mono',monospace;color:var(--color-ink);outline:none;box-sizing:border-box"
      />
      <div class="field-error" data-field="publishedAt" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-error);margin-top:4px;display:none"></div>
    </div>
  </div>

  <!-- Featured -->
  <div>
    <label style="display:inline-flex;align-items:center;gap:8px;font:400 13px 'Space Grotesk',sans-serif;color:var(--color-ink);cursor:pointer">
      <input type="checkbox" id="featured" name="featured" checked={post?.featured} style="width:16px;height:16px;accent-color:#3a7d6c" />
      Featured post
    </label>
  </div>

  <!-- Focus keyword -->
  <div>
    <label for="focusKeyword" style="display:block;font:500 11px 'IBM Plex Mono',monospace;color:var(--color-meta);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em">Focus Keyword</label>
    <input
      type="text"
      id="focusKeyword"
      name="focusKeyword"
      value={post?.focusKeyword ?? ''}
      placeholder="e.g. react server components"
      style="width:100%;height:36px;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:0 10px;font:400 13px 'IBM Plex Mono',monospace;color:var(--color-ink);outline:none;box-sizing:border-box"
    />
    <div style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-placeholder);margin-top:4px">The main keyword you want this post to rank for</div>
  </div>

  <!-- Excerpt -->
  <div>
    <label for="excerpt" style="display:block;font:500 11px 'IBM Plex Mono',monospace;color:var(--color-meta);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em">Excerpt</label>
    <textarea
      id="excerpt"
      name="excerpt"
      rows="3"
      required
      style="width:100%;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:10px;font:400 13px 'Space Grotesk',sans-serif;color:var(--color-ink);outline:none;resize:vertical;box-sizing:border-box;line-height:1.5"
    >{post?.excerpt ?? ''}</textarea>
    <div class="field-error" data-field="excerpt" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-error);margin-top:4px;display:none"></div>
  </div>

  <!-- Body + Preview -->
  <div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
      <label for="body" style="font:500 11px 'IBM Plex Mono',monospace;color:var(--color-meta);text-transform:uppercase;letter-spacing:.06em">Body</label>
      <label style="display:inline-flex;align-items:center;gap:6px;font:400 11px 'IBM Plex Mono',monospace;color:var(--color-meta);cursor:pointer">
        <input type="checkbox" id="sync-scroll" style="width:12px;height:12px;accent-color:#3a7d6c" />
        sync scroll
      </label>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;min-height:400px">
      <textarea
        id="body"
        name="body"
        required
        style="width:100%;height:100%;min-height:400px;border:1px solid var(--color-border);background:var(--color-surface);border-radius:6px;padding:12px;font:400 13px 'IBM Plex Mono',monospace;color:var(--color-ink);outline:none;resize:vertical;box-sizing:border-box;line-height:1.6"
      >{post?.body ?? ''}</textarea>
      <div id="preview-panel" style="border:1px solid var(--color-border-light);border-radius:6px;background:var(--color-surface);overflow-y:auto;min-height:400px">
        <markdown-preview content={post?.body ?? ''}></markdown-preview>
      </div>
    </div>
    <div class="field-error" data-field="body" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-error);margin-top:4px;display:none"></div>
  </div>

  <!-- SEO panel -->
  <seo-panel></seo-panel>

  <!-- Submit -->
  <div style="display:flex;flex-direction:column;gap:14px">
    {isDraft && (
      <label style="display:inline-flex;align-items:center;gap:8px;font:400 13px 'Space Grotesk',sans-serif;color:var(--color-meta);cursor:pointer">
        <input type="checkbox" id="notify" style="width:16px;height:16px;accent-color:#3a7d6c" />
        Notify subscribers when published
      </label>
    )}
    <div style="display:flex;align-items:center;gap:12px">
    {isDraft && (
      <>
        <button
          type="submit"
          data-status={POST_STATUS.PUBLISHED}
          class="submit-action"
          style="height:38px;background:#3a7d6c;border:none;border-radius:6px;padding:0 24px;font:500 13px 'IBM Plex Mono',monospace;color:#fff;cursor:pointer"
        >Publish</button>
        <button
          type="submit"
          data-status={POST_STATUS.DRAFT}
          class="submit-action"
          style="height:38px;background:transparent;border:1px solid var(--color-border);border-radius:6px;padding:0 24px;font:500 13px 'IBM Plex Mono',monospace;color:var(--color-ink);cursor:pointer"
        >{isEdit ? 'Save Draft' : 'Save as Draft'}</button>
      </>
    )}
    {isPublished && (
      <button
        type="submit"
        data-status={POST_STATUS.PUBLISHED}
        class="submit-action"
        style="height:38px;background:#3a7d6c;border:none;border-radius:6px;padding:0 24px;font:500 13px 'IBM Plex Mono',monospace;color:#fff;cursor:pointer"
      >Update Post</button>
    )}
    {isArchived && (
      <button
        type="submit"
        data-status={POST_STATUS.ARCHIVED}
        class="submit-action"
        style="height:38px;background:#3a7d6c;border:none;border-radius:6px;padding:0 24px;font:500 13px 'IBM Plex Mono',monospace;color:#fff;cursor:pointer"
      >Update</button>
    )}
    <span id="form-status" style="font:400 12px 'IBM Plex Mono',monospace;display:none"></span>
    </div>
  </div>
</form>

<script define:vars={{ action, method, currentStatus, ADD_NEW_SENTINEL, initialTitle: post?.title ?? '', initialSlug: post?.slug ?? '', initialExcerpt: post?.excerpt ?? '', initialBody: post?.body ?? '', initialKeyword: post?.focusKeyword ?? '' }}>
  const form = document.getElementById('post-form');
  const titleInput = document.getElementById('title');
  const bodyTextarea = document.getElementById('body');
  const excerptTextarea = document.getElementById('excerpt');
  const focusKeywordInput = document.getElementById('focusKeyword');
  const slugField = document.querySelector('slug-field');
  const preview = document.querySelector('markdown-preview');
  const seoPanel = document.querySelector('seo-panel');
  const formStatus = document.getElementById('form-status');
  const areaHidden = document.getElementById('area');
  const areaSelect = document.getElementById('area-select');
  const areaCustom = document.getElementById('area-custom');
  const submitButtons = form.querySelectorAll('.submit-action');

  function updateSeoPanel() {
    seoPanel.keyword = focusKeywordInput.value;
    seoPanel.title = titleInput.value;
    seoPanel.slug = slugField.value;
    seoPanel.excerpt = excerptTextarea.value;
    seoPanel.body = bodyTextarea.value;
  }

  seoPanel.keyword = initialKeyword;
  seoPanel.title = initialTitle;
  seoPanel.slug = initialSlug;
  seoPanel.excerpt = initialExcerpt;
  seoPanel.body = initialBody;

  areaSelect.addEventListener('change', () => {
    if (areaSelect.value === ADD_NEW_SENTINEL) {
      areaCustom.style.display = 'block';
      areaCustom.focus();
      areaHidden.value = '';
    } else {
      areaCustom.style.display = 'none';
      areaCustom.value = '';
      areaHidden.value = areaSelect.value;
    }
  });

  areaCustom.addEventListener('input', () => {
    areaHidden.value = areaCustom.value.trim().toLowerCase().replace(/\s+/g, '-');
  });

  titleInput.addEventListener('input', () => {
    slugField.title = titleInput.value;
    requestAnimationFrame(updateSeoPanel);
  });

  excerptTextarea.addEventListener('input', updateSeoPanel);
  focusKeywordInput.addEventListener('input', updateSeoPanel);

  const previewPanel = document.getElementById('preview-panel');
  new ResizeObserver(() => {
    previewPanel.style.height = bodyTextarea.offsetHeight + 'px';
  }).observe(bodyTextarea);

  const syncScrollCheckbox = document.getElementById('sync-scroll');
  let scrollSyncing = false;
  function syncScroll(source, target) {
    if (scrollSyncing || !syncScrollCheckbox.checked) return;
    scrollSyncing = true;
    const ratio = source.scrollTop / (source.scrollHeight - source.clientHeight) || 0;
    target.scrollTop = ratio * (target.scrollHeight - target.clientHeight);
    scrollSyncing = false;
  }
  bodyTextarea.addEventListener('scroll', () => syncScroll(bodyTextarea, previewPanel));
  previewPanel.addEventListener('scroll', () => syncScroll(previewPanel, bodyTextarea));

  bodyTextarea.addEventListener('input', () => {
    preview.content = bodyTextarea.value;
    updateSeoPanel();
  });

  function clearErrors() {
    document.querySelectorAll('.field-error').forEach(el => {
      el.style.display = 'none';
      el.textContent = '';
    });
  }

  function showErrors(errors) {
    for (const [field, message] of Object.entries(errors)) {
      const el = document.querySelector(`.field-error[data-field="${field}"]`);
      if (el) {
        el.textContent = message;
        el.style.display = 'block';
      }
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const status = e.submitter?.dataset?.status || currentStatus;
    const submitter = e.submitter;
    const originalText = submitter?.textContent;
    const notifyCheckbox = document.getElementById('notify');

    const fd = new FormData(form);
    const data = {
      title: fd.get('title'),
      slug: fd.get('slug'),
      area: fd.get('area'),
      publishedAt: new Date(fd.get('publishedAt')).toISOString(),
      featured: fd.has('featured'),
      focusKeyword: fd.get('focusKeyword') ?? '',
      excerpt: fd.get('excerpt'),
      body: fd.get('body'),
      status,
      notify: status === 'published' && !!notifyCheckbox?.checked,
    };

    submitButtons.forEach(btn => btn.disabled = true);
    if (submitter) submitter.textContent = 'Saving…';
    formStatus.style.display = 'none';

    try {
      const res = await fetch(action, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (!res.ok) {
        if (result.errors) {
          showErrors(result.errors);
        } else {
          formStatus.textContent = result.error || 'Something went wrong';
          formStatus.style.color = 'var(--color-error)';
          formStatus.style.display = 'inline';
        }
        return;
      }

      formStatus.textContent = 'Saved!';
      formStatus.style.color = 'var(--color-accent)';
      formStatus.style.display = 'inline';

      if (method === 'POST') {
        const redirect = status === 'draft' ? '/admin/posts?tab=drafts' : '/admin/posts';
        setTimeout(() => { window.location.href = redirect; }, 600);
      }
    } catch {
      formStatus.textContent = 'Network error';
      formStatus.style.color = 'var(--color-error)';
      formStatus.style.display = 'inline';
    } finally {
      submitButtons.forEach(btn => btn.disabled = false);
      if (submitter) submitter.textContent = originalText;
    }
  });
</script>

<script>
  import './SlugField';
  import './MarkdownPreview';
  import './SeoPanel';
</script>
