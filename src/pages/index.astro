---
import BaseLayout from '../layouts/Base.astro';
import { getPosts, getPage, getProfile } from '../lib/api';
import { env } from 'cloudflare:workers';
import { PAGE_SLUG, LATEST_POSTS_COUNT, NOW_SNIPPET_LENGTH, SITE_TITLE } from '../consts';
import { stripMarkdown, truncate } from '../lib/format';

const posts = await getPosts(env.DB);
const latestPosts = posts.slice(0, LATEST_POSTS_COUNT);
const nowPage = await getPage(env.DB, PAGE_SLUG.NOW);
const profile = await getProfile(env.DB);

const nowSnippet = nowPage
  ? truncate(stripMarkdown(nowPage.body), NOW_SNIPPET_LENGTH)
  : null;
---

<BaseLayout>
  <div class="page-container">

    {profile && (
      <section class="flex gap-8 items-start px-[26px] pt-12 pb-10 max-sm:flex-col max-sm:gap-[18px] max-sm:px-4 max-sm:pt-6 max-sm:pb-5">
        <div class="flex-1">
          {profile.heroName && <h1 class="font-heading font-normal text-[36px] leading-[1.2] text-ink m-0 max-sm:text-[26px]">{profile.heroName}</h1>}
          {profile.heroBio && <p class="mt-[18px] font-heading text-base leading-[1.65] text-body max-w-[420px] max-sm:max-w-none max-sm:text-[15px]">{profile.heroBio}</p>}
          {profile.heroTagline && <div class="mt-5 font-mono text-[11px] text-dim tracking-[.04em]">{profile.heroTagline}</div>}
        </div>
        {profile.heroPhoto && (
          <div class="shrink-0 w-[280px] rounded-lg overflow-hidden border border-border shadow-[0_4px_24px_rgba(0,0,0,.08)] max-sm:w-full">
            <div class="flex items-center gap-2 py-[7px] px-2.5 bg-surface-alt border-b border-border-light">
              <span class="flex gap-[5px]">
                <span class="size-[7px] rounded-full bg-border"></span>
                <span class="size-[7px] rounded-full bg-border"></span>
                <span class="size-[7px] rounded-full bg-border"></span>
              </span>
              <span class="font-mono text-[9px] text-dim tracking-[.02em]">~/photos/summit.jpg</span>
            </div>
            <div class="relative leading-none">
              <img src={profile.heroPhoto} alt={SITE_TITLE} class="w-full h-[240px] object-cover object-[center_40%] block max-sm:h-[180px]" />
            </div>
          </div>
        )}
      </section>
    )}

    <section class="px-[26px] py-2 pb-[10px] max-sm:px-4">
      <div class="flex items-baseline justify-between mb-1">
        <span class="section-label">latest writing</span>
        <a href="/writing" class="font-mono text-[11px] text-dim no-underline transition-colors duration-150 hover:text-indigo">view all &rarr;</a>
      </div>
      {latestPosts.map(post => (
        <a href={`/writing/${post.slug}`} class="group block py-3.5 border-b border-border-light no-underline text-inherit hover:text-inherit hover:pl-1.5 transition-[padding-left] duration-200">
          <div class="font-heading text-[17px] text-ink transition-colors duration-150 group-hover:text-indigo">{post.title}</div>
          <div class="font-mono text-[11px] text-dim mt-[5px]">
            {post.publishedAt.slice(0, 7)} &middot; <span class="text-indigo">{post.area}</span>
            {post.readTime ? <span> &middot; {post.readTime} min</span> : null}
          </div>
        </a>
      ))}
    </section>

    <div class="flex gap-4 px-[26px] pt-[22px] pb-7 max-sm:flex-col max-sm:px-4 max-sm:pt-[18px] max-sm:pb-6">
      <a href="/now" class="flex-1 relative border border-dashed border-border rounded-lg pt-7 px-4 pb-4 no-underline block text-inherit hover:text-inherit transition-all duration-200 hover:border-indigo hover:shadow-[0_2px_12px_rgba(79,86,232,.08)]">
        <span class="absolute top-[9px] left-3 flex items-center gap-[5px] font-mono text-[9px] font-medium tracking-[.1em] text-placeholder uppercase">
          <span class="size-1.5 rounded-full bg-[#34d399] animate-pulse-dot"></span>
          now
        </span>
        {nowSnippet ? (
          <div class="font-heading text-[13px] leading-[1.6] text-body">{nowSnippet}</div>
        ) : (
          <div>
            <div class="h-2 bg-skeleton rounded-[3px] mb-[7px] w-[88%]"></div>
            <div class="h-2 bg-skeleton rounded-[3px] w-[64%]"></div>
          </div>
        )}
      </a>
      <div class="flex-1 bg-newsletter-bg rounded-lg p-[18px]">
        <newsletter-form></newsletter-form>
      </div>
    </div>

  </div>
</BaseLayout>
