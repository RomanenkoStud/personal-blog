---
import BaseLayout from '../layouts/Base.astro';
import WindowFrame from '@/components/ui/WindowFrame.astro';
import { getPostsList } from '@/server/repositories/posts';
import { getPage } from '@/server/repositories/pages';
import { getProfile } from '@/server/services/profile';
import { env } from 'cloudflare:workers';
import { PAGE_SLUG, FEATURED_POSTS_COUNT, LATEST_POSTS_COUNT, NOW_SNIPPET_LENGTH, SITE_TITLE } from '@/config';
import { stripMarkdown, truncate } from '@/lib/format';

const [featuredResult, latestResult, nowPage, profile] = await Promise.all([
  getPostsList(env.DB, { page: 1, perPage: FEATURED_POSTS_COUNT, filters: { featured: 'true' } }),
  getPostsList(env.DB, { page: 1, perPage: LATEST_POSTS_COUNT, filters: { featured: 'false' } }),
  getPage(env.DB, PAGE_SLUG.NOW),
  getProfile(env.DB),
]);

const [leadPost, ...runnerUpPosts] = featuredResult.items;
const latestPosts = latestResult.items;

const nowSnippet = nowPage
  ? truncate(stripMarkdown(nowPage.body), NOW_SNIPPET_LENGTH)
  : null;
---

<BaseLayout>
  <div class="page-container">

    {profile && (
      <section class="flex gap-8 items-start px-[26px] pt-12 pb-10 max-sm:flex-col max-sm:gap-[18px] max-sm:px-4 max-sm:pt-6 max-sm:pb-5">
        <div class="flex-1">
          {profile.heroName && <h1 class="font-display font-normal text-[36px] leading-[1.2] text-ink m-0 max-sm:text-[26px]">{profile.heroName}</h1>}
          {profile.heroBio && <p class="mt-[18px] font-heading text-base leading-[1.65] text-body max-w-[420px] max-sm:max-w-none max-sm:text-[15px]">{profile.heroBio}</p>}
          {profile.heroTagline && <div class="mt-5 font-mono text-[11px] text-dim tracking-[.04em]">{profile.heroTagline}</div>}
        </div>
        {profile.heroPhoto && (
          <WindowFrame label="~/photos/summit.jpg" class="shrink-0 w-[280px] max-sm:w-full">
            <img src={profile.heroPhoto} alt={SITE_TITLE} class="w-full h-[240px] object-cover object-[center_40%] block max-sm:h-[180px]" />
          </WindowFrame>
        )}
      </section>
    )}

    {leadPost && (
      <section class="px-[26px] pt-3 pb-4 max-sm:px-4">
        <span class="section-label"><span class="text-accent not-italic">&#9733;</span> featured</span>

        <a href={`/writing/${leadPost.slug}`} class="group block mt-3 pl-4 border-l-2 border-accent no-underline text-inherit hover:text-inherit">
          <div class="font-heading text-[21px] leading-[1.3] text-ink transition-colors duration-150 group-hover:text-accent max-sm:text-[19px]">{leadPost.title}</div>
          {leadPost.excerpt && (
            <div class="mt-1.5 font-heading text-[13.5px] leading-[1.55] text-meta line-clamp-1 max-sm:line-clamp-2">{leadPost.excerpt}</div>
          )}
          <div class="font-mono text-[11px] text-dim mt-2">
            {leadPost.publishedAt.slice(0, 7)} &middot; <span class="text-accent">{leadPost.area}</span>
            {leadPost.readTime ? <span> &middot; {leadPost.readTime} min</span> : null}
          </div>
        </a>

        {runnerUpPosts.length > 0 && (
          <div class="grid grid-cols-2 gap-x-7 mt-4 max-sm:grid-cols-1 max-sm:gap-x-0">
            {runnerUpPosts.map(post => (
              <a href={`/writing/${post.slug}`} class="group block py-3 border-t border-border-light no-underline text-inherit hover:text-inherit">
                <div class="font-heading text-[15px] leading-[1.35] text-ink transition-colors duration-150 group-hover:text-accent">{post.title}</div>
                <div class="font-mono text-[11px] text-dim mt-1">
                  {post.publishedAt.slice(0, 7)} &middot; <span class="text-accent">{post.area}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>
    )}

    <section class="px-[26px] py-2 pb-[10px] max-sm:px-4">
      <div class="flex items-baseline justify-between mb-1">
        <span class="section-label">latest writing</span>
        <a href="/writing" class="font-mono text-[11px] text-dim no-underline transition-colors duration-150 hover:text-accent">view all &rarr;</a>
      </div>
      {latestPosts.map(post => (
        <a href={`/writing/${post.slug}`} class="group block py-3.5 border-b border-border-light no-underline text-inherit hover:text-inherit hover:pl-1.5 transition-[padding-left] duration-200">
          <div class="font-heading text-[17px] text-ink transition-colors duration-150 group-hover:text-accent">{post.title}</div>
          <div class="font-mono text-[11px] text-dim mt-[5px]">
            {post.publishedAt.slice(0, 7)} &middot; <span class="text-accent">{post.area}</span>
            {post.readTime ? <span> &middot; {post.readTime} min</span> : null}
          </div>
        </a>
      ))}
    </section>

    <div class="flex gap-4 px-[26px] pt-[22px] pb-7 max-sm:flex-col max-sm:px-4 max-sm:pt-[18px] max-sm:pb-6">
      <a href="/now" class="flex-1 relative border border-dashed border-border rounded-none pt-7 px-4 pb-4 no-underline block text-inherit hover:text-inherit transition-all duration-200 hover:border-accent">
        <span class="absolute top-[9px] left-3 flex items-center gap-[5px] font-mono text-[9px] font-medium tracking-[.1em] text-placeholder uppercase">
          <span class="size-1.5 rounded-full bg-[#34d399] animate-pulse-dot"></span>
          now
        </span>
        {nowSnippet ? (
          <div class="font-heading text-[13px] leading-[1.6] text-body">{nowSnippet}</div>
        ) : (
          <div>
            <div class="h-2 bg-skeleton rounded-none mb-[7px] w-[88%]"></div>
            <div class="h-2 bg-skeleton rounded-none w-[64%]"></div>
          </div>
        )}
      </a>
      <div class="flex-1 bg-newsletter-bg rounded-none p-[18px]">
        <newsletter-form></newsletter-form>
      </div>
    </div>

  </div>
</BaseLayout>
