---
import BaseLayout from '../../../../layouts/Base.astro';
import { getPostById } from '@/server/repositories/posts';
import { env } from 'cloudflare:workers';
import { RELATED_POSTS_COUNT, RELATED_TITLE_MAX_LENGTH, POST_STATUS } from '@/config';
import { formatMonthYear } from '@/lib/format';
import PostBody from '@/components/ui/PostBody.astro';

const id = Number(Astro.params.id);
if (isNaN(id)) {
  return Astro.redirect('/admin/posts');
}

const post = await getPostById(env.DB, id);

if (!post) {
  return Astro.redirect('/admin/posts');
}

const dateLabel = formatMonthYear(post.publishedAt).toUpperCase();
const isDraft = post.status === POST_STATUS.DRAFT;
const isArchived = post.status === POST_STATUS.ARCHIVED;
---

<BaseLayout
  title={`[Preview] ${post.title}`}
  description={post.excerpt}
  ogType="article"
  noIndex={true}
>
  <article class="page-container">

    <!-- Draft preview banner -->
    <div class="mx-[92px] mt-8 mb-0 max-sm:mx-4 max-sm:mt-5">
      <div class="flex items-center justify-between gap-2 py-2.5 px-4 rounded-md border border-dashed border-indigo/40 bg-indigo/5">
        <div class="flex items-center gap-2">
          <span class="font-mono text-[10px] font-medium tracking-[.1em] text-indigo uppercase">{post.status} preview</span>
          <span class="font-heading text-[12px] text-dim">This is how the article will look once published. Not visible to the public.</span>
        </div>
        <a
          href={`/admin/posts/${post.id}`}
          id="back-to-editor"
          class="font-mono text-[10px] text-indigo no-underline hover:text-periwinkle shrink-0"
        >
          ← Back to editor
        </a>
      </div>
    </div>

    {isArchived && (
      <div class="mx-[92px] mt-3 mb-0 max-sm:mx-4">
        <div class="flex items-center gap-2 py-2.5 px-4 rounded-md border border-dashed border-border bg-surface-alt">
          <span class="font-mono text-[10px] font-medium tracking-[.1em] text-placeholder uppercase">archived</span>
          <span class="font-heading text-[12px] text-dim">This article is no longer listed but remains accessible via direct link.</span>
        </div>
      </div>
    )}

    <!-- Header -->
    <div class="px-[92px] pt-11 pb-8 text-center max-sm:px-4 max-sm:pt-7 max-sm:pb-5">
      <div class="font-mono text-[11px] text-dim mb-[18px]">{post.area.toUpperCase()} &middot; {post.readTime} MIN &middot; {dateLabel}</div>
      <div class="font-heading text-[30px] leading-[1.25] text-ink max-sm:text-2xl">{post.title}</div>
      {post.excerpt && (
        <div class="mt-4 font-heading text-[13px] italic text-meta">{post.excerpt}</div>
      )}
    </div>

    <!-- Body -->
    <div class="px-[92px] pb-2 max-sm:px-4">
      <PostBody body={post.body} />
    </div>

    <!-- Related notes placeholder for drafts -->
    {isDraft && (
      <div class="mx-[92px] mt-3 mb-[30px] border-t border-border-light pt-[18px] max-sm:mx-4 max-sm:mb-6">
        <span class="font-mono font-medium text-[9px] tracking-[.1em] text-placeholder uppercase">related notes — shown after publish</span>
      </div>
    )}

  </article>
</BaseLayout>

<script>
  import '@/components/ui/CodeSandbox';

  // COOP: same-origin (required for sandbox embeds) severs window.opener so the
  // preview tab can't call opener.focus(). window.close() is the reliable way to
  // return to the originating editor tab when the preview was opened via
  // target="_blank". If close() is blocked (e.g. user navigated here directly),
  // the <a> href is the fallback.
  document.getElementById('back-to-editor')?.addEventListener('click', (e) => {
    e.preventDefault();
    const href = (e.currentTarget as HTMLAnchorElement).href;
    if (window.history.length <= 1) {
      window.close();
      // If close() was blocked by the browser, navigate to the editor directly.
      window.location.href = href;
    } else {
      window.history.back();
    }
  });
</script>
