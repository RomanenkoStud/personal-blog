---
import AdminLayout from '../../layouts/Admin.astro';
import { getPage } from '@/server/repositories/pages';
import { getProfile } from '@/server/services/profile';
import { env } from 'cloudflare:workers';
import { PAGE_SLUG } from '@/config';
import type { ProfileData } from '@/types/content';

const page = await getPage(env.DB, PAGE_SLUG.ABOUT);
const profile = await getProfile(env.DB);

const EMPTY: ProfileData = {
  heroName: '', heroBio: '', heroTagline: '', heroPhoto: '',
  tagline: '', bio: '', photo: '', location: '',
  socials: [], whatIDo: [], experience: [], education: [], tech: [], cta: '',
};
const data = profile ?? EMPTY;
const pageId = page?.id ?? null;
---

<AdminLayout title="Profile" activeNav="profile">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
    <div style="font:400 26px 'Space Grotesk',sans-serif;color:var(--color-ink)">Profile</div>
    <a href="/about" target="_blank" style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-accent);text-decoration:none">View on site →</a>
  </div>

  <form id="profile-form" style="display:flex;flex-direction:column;gap:24px;max-width:720px">

    <!-- Homepage hero -->
    <div class="section-divider">Homepage</div>

    <div class="field">
      <label for="heroName" class="field-label">Hero heading</label>
      <input type="text" id="heroName" name="heroName" value={data.heroName} class="field-input" placeholder="Hi, I'm..." />
    </div>

    <div class="field">
      <label for="heroBio" class="field-label">Hero bio</label>
      <textarea id="heroBio" name="heroBio" rows="2" class="field-textarea" placeholder="A short bio for the homepage hero...">{data.heroBio}</textarea>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
      <div class="field">
        <label for="heroTagline" class="field-label">Hero tagline</label>
        <input type="text" id="heroTagline" name="heroTagline" value={data.heroTagline} class="field-input" placeholder="role · focus · location" />
      </div>
      <div class="field">
        <label for="heroPhoto" class="field-label">Hero photo path</label>
        <input type="text" id="heroPhoto" name="heroPhoto" value={data.heroPhoto} class="field-input" placeholder="/media/photo.jpg" />
      </div>
    </div>

    <!-- About page -->
    <div class="section-divider">About page</div>

    <!-- Tagline -->
    <div class="field">
      <label for="tagline" class="field-label">Tagline</label>
      <input type="text" id="tagline" name="tagline" value={data.tagline} class="field-input" placeholder="Your main heading..." />
    </div>

    <!-- Bio -->
    <div class="field">
      <label for="bio" class="field-label">Bio</label>
      <textarea id="bio" name="bio" rows="3" class="field-textarea" placeholder="Short paragraph about yourself...">{data.bio}</textarea>
    </div>

    <!-- Photo + Location row -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
      <div class="field">
        <label for="photo" class="field-label">Photo path</label>
        <input type="text" id="photo" name="photo" value={data.photo} class="field-input" placeholder="/media/photo.jpg" />
      </div>
      <div class="field">
        <label for="location" class="field-label">Location</label>
        <input type="text" id="location" name="location" value={data.location} class="field-input" placeholder="city · remote" />
      </div>
    </div>

    <!-- Socials -->
    <div class="field">
      <label class="field-label">Socials</label>
      <div id="socials-list" style="display:flex;flex-direction:column;gap:8px">
        {data.socials.map(s => (
          <div class="social-row" style="display:flex;gap:8px;align-items:center">
            <input type="text" name="social-label" value={s.label} class="field-input" style="width:120px;flex:none" placeholder="github" />
            <input type="text" name="social-url" value={s.url} class="field-input" style="flex:1" placeholder="https://..." />
            <button type="button" class="remove-btn" title="Remove">×</button>
          </div>
        ))}
      </div>
      <button type="button" id="add-social" class="add-btn">+ add link</button>
    </div>

    <!-- What I Do -->
    <div class="field">
      <label class="field-label">What I Do</label>
      <div id="what-i-do-list" style="display:flex;flex-direction:column;gap:8px">
        {data.whatIDo.map((item, i) => (
          <div class="list-row" style="display:flex;gap:8px;align-items:center">
            <span class="row-number">{String(i + 1).padStart(2, '0')}</span>
            <input type="text" name="whatIDo" value={item} class="field-input" style="flex:1" placeholder="Describe what you do..." />
            <button type="button" class="remove-btn" title="Remove">×</button>
          </div>
        ))}
      </div>
      <button type="button" id="add-what-i-do" class="add-btn">+ add item</button>
    </div>

    <!-- Experience -->
    <div class="field">
      <label class="field-label">Experience</label>
      <div id="experience-list" style="display:flex;flex-direction:column;gap:14px">
        {data.experience.map(exp => (
          <div class="exp-row" style="border:1px solid var(--color-border-light);border-radius:6px;padding:12px;display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;gap:8px;align-items:center">
              <input type="text" name="exp-title" value={exp.title} class="field-input" style="flex:1" placeholder="Role · Company" />
              <button type="button" class="remove-btn" title="Remove">×</button>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center">
              <div>
                <label class="field-label-sm">Start</label>
                <input type="month" name="exp-start" value={exp.startDate} class="field-input" />
              </div>
              <div>
                <label class="field-label-sm">End</label>
                <div style="display:flex;flex-direction:column;gap:4px">
                  <input type="month" name="exp-end" value={exp.endDate} class="field-input" disabled={!exp.endDate} />
                  <label class="present-label"><input type="checkbox" name="exp-present" checked={!exp.endDate} class="present-check" /> Present</label>
                </div>
              </div>
              <div>
                <label class="field-label-sm">Location</label>
                <input type="text" name="exp-location" value={exp.location} class="field-input" placeholder="hybrid" />
              </div>
            </div>
          </div>
        ))}
      </div>
      <button type="button" id="add-experience" class="add-btn">+ add entry</button>
    </div>

    <!-- Education -->
    <div class="field">
      <label class="field-label">Education</label>
      <div id="education-list" style="display:flex;flex-direction:column;gap:14px">
        {data.education.map(edu => (
          <div class="edu-row" style="border:1px solid var(--color-border-light);border-radius:6px;padding:12px;display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;gap:8px;align-items:center">
              <input type="text" name="edu-title" value={edu.title} class="field-input" style="flex:1" placeholder="Degree · Institution" />
              <button type="button" class="remove-btn" title="Remove">×</button>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center">
              <div>
                <label class="field-label-sm">Start</label>
                <input type="month" name="edu-start" value={edu.startDate} class="field-input" />
              </div>
              <div>
                <label class="field-label-sm">End</label>
                <div style="display:flex;flex-direction:column;gap:4px">
                  <input type="month" name="edu-end" value={edu.endDate} class="field-input" disabled={!edu.endDate} />
                  <label class="present-label"><input type="checkbox" name="edu-present" checked={!edu.endDate} class="present-check" /> Present</label>
                </div>
              </div>
              <div>
                <label class="field-label-sm">Location</label>
                <input type="text" name="edu-location" value={edu.location} class="field-input" placeholder="City" />
              </div>
            </div>
          </div>
        ))}
      </div>
      <button type="button" id="add-education" class="add-btn">+ add entry</button>
    </div>

    <!-- Tech -->
    <div class="field">
      <label class="field-label">Tech</label>
      <div id="tech-tags" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px">
        {data.tech.map(t => (
          <span class="tag">{t}<button type="button" class="tag-remove" title="Remove">×</button></span>
        ))}
      </div>
      <div style="display:flex;gap:8px">
        <input type="text" id="tech-input" class="field-input" style="flex:1" placeholder="Type a tech and press Enter..." />
        <button type="button" id="add-tech" class="add-btn" style="margin-top:0">add</button>
      </div>
    </div>

    <!-- CTA -->
    <div class="field">
      <label for="cta" class="field-label">CTA text</label>
      <input type="text" id="cta" name="cta" value={data.cta} class="field-input" placeholder="Call to action text..." />
    </div>

    <!-- Submit -->
    <div style="display:flex;align-items:center;gap:12px;padding-top:4px">
      <button type="submit" id="submit-btn" class="submit-btn">Save Profile</button>
      <button type="button" id="sync-gh-btn" class="submit-btn" style="background:var(--color-ink)">Sync to GitHub</button>
      <span id="form-status" style="font:400 12px 'IBM Plex Mono',monospace;display:none"></span>
    </div>

  </form>

</AdminLayout>

<script define:vars={{ pageId }}>
  const form = document.getElementById('profile-form');
  const submitBtn = document.getElementById('submit-btn');
  const formStatus = document.getElementById('form-status');

  // --- Socials: add/remove ---
  const socialsList = document.getElementById('socials-list');
  document.getElementById('add-social').addEventListener('click', () => {
    const row = document.createElement('div');
    row.className = 'social-row';
    row.style.cssText = 'display:flex;gap:8px;align-items:center';
    row.innerHTML = `
      <input type="text" name="social-label" class="field-input" style="width:120px;flex:none" placeholder="github" />
      <input type="text" name="social-url" class="field-input" style="flex:1" placeholder="https://..." />
      <button type="button" class="remove-btn" title="Remove">×</button>
    `;
    socialsList.appendChild(row);
  });
  socialsList.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-btn')) {
      e.target.closest('.social-row').remove();
    }
  });

  // --- What I Do: add/remove ---
  const whatList = document.getElementById('what-i-do-list');
  document.getElementById('add-what-i-do').addEventListener('click', () => {
    const count = whatList.querySelectorAll('.list-row').length;
    const row = document.createElement('div');
    row.className = 'list-row';
    row.style.cssText = 'display:flex;gap:8px;align-items:center';
    row.innerHTML = `
      <span class="row-number">${String(count + 1).padStart(2, '0')}</span>
      <input type="text" name="whatIDo" class="field-input" style="flex:1" placeholder="Describe what you do..." />
      <button type="button" class="remove-btn" title="Remove">×</button>
    `;
    whatList.appendChild(row);
    renumberRows(whatList);
  });
  whatList.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-btn')) {
      e.target.closest('.list-row').remove();
      renumberRows(whatList);
    }
  });

  function renumberRows(container) {
    container.querySelectorAll('.row-number').forEach((el, i) => {
      el.textContent = String(i + 1).padStart(2, '0');
    });
  }

  // --- Experience: add/remove + present toggle ---
  const expList = document.getElementById('experience-list');
  document.getElementById('add-experience').addEventListener('click', () => {
    const row = document.createElement('div');
    row.className = 'exp-row';
    row.style.cssText = 'border:1px solid var(--color-border-light);border-radius:6px;padding:12px;display:flex;flex-direction:column;gap:8px';
    row.innerHTML = `
      <div style="display:flex;gap:8px;align-items:center">
        <input type="text" name="exp-title" class="field-input" style="flex:1" placeholder="Role · Company" />
        <button type="button" class="remove-btn" title="Remove">×</button>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center">
        <div>
          <label class="field-label-sm">Start</label>
          <input type="month" name="exp-start" class="field-input" />
        </div>
        <div>
          <label class="field-label-sm">End</label>
          <div style="display:flex;flex-direction:column;gap:4px">
            <input type="month" name="exp-end" class="field-input" disabled />
            <label class="present-label"><input type="checkbox" name="exp-present" class="present-check" checked /> Present</label>
          </div>
        </div>
        <div>
          <label class="field-label-sm">Location</label>
          <input type="text" name="exp-location" class="field-input" placeholder="hybrid" />
        </div>
      </div>
    `;
    expList.appendChild(row);
  });
  expList.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-btn')) {
      e.target.closest('.exp-row').remove();
    }
  });
  expList.addEventListener('change', (e) => {
    if (e.target.classList.contains('present-check')) {
      const endInput = e.target.closest('.exp-row').querySelector('input[name="exp-end"]');
      endInput.disabled = e.target.checked;
      if (e.target.checked) endInput.value = '';
    }
  });

  // --- Education: add/remove + present toggle ---
  const eduList = document.getElementById('education-list');
  document.getElementById('add-education').addEventListener('click', () => {
    const row = document.createElement('div');
    row.className = 'edu-row';
    row.style.cssText = 'border:1px solid var(--color-border-light);border-radius:6px;padding:12px;display:flex;flex-direction:column;gap:8px';
    row.innerHTML = `
      <div style="display:flex;gap:8px;align-items:center">
        <input type="text" name="edu-title" class="field-input" style="flex:1" placeholder="Degree · Institution" />
        <button type="button" class="remove-btn" title="Remove">×</button>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center">
        <div>
          <label class="field-label-sm">Start</label>
          <input type="month" name="edu-start" class="field-input" />
        </div>
        <div>
          <label class="field-label-sm">End</label>
          <div style="display:flex;flex-direction:column;gap:4px">
            <input type="month" name="edu-end" class="field-input" disabled />
            <label class="present-label"><input type="checkbox" name="edu-present" class="present-check" checked /> Present</label>
          </div>
        </div>
        <div>
          <label class="field-label-sm">Location</label>
          <input type="text" name="edu-location" class="field-input" placeholder="City" />
        </div>
      </div>
    `;
    eduList.appendChild(row);
  });
  eduList.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-btn')) {
      e.target.closest('.edu-row').remove();
    }
  });
  eduList.addEventListener('change', (e) => {
    if (e.target.classList.contains('present-check')) {
      const endInput = e.target.closest('.edu-row').querySelector('input[name="edu-end"]');
      endInput.disabled = e.target.checked;
      if (e.target.checked) endInput.value = '';
    }
  });

  // --- Tech tags ---
  const techTags = document.getElementById('tech-tags');
  const techInput = document.getElementById('tech-input');

  function addTag(text) {
    text = text.trim();
    if (!text) return;
    const span = document.createElement('span');
    span.className = 'tag';
    span.innerHTML = `${text}<button type="button" class="tag-remove" title="Remove">×</button>`;
    techTags.appendChild(span);
    techInput.value = '';
  }

  document.getElementById('add-tech').addEventListener('click', () => addTag(techInput.value));
  techInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); addTag(techInput.value); }
  });
  techTags.addEventListener('click', (e) => {
    if (e.target.classList.contains('tag-remove')) {
      e.target.closest('.tag').remove();
    }
  });

  // --- Submit ---
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const body = JSON.stringify({
      heroName: form.querySelector('#heroName').value,
      heroBio: form.querySelector('#heroBio').value,
      heroTagline: form.querySelector('#heroTagline').value,
      heroPhoto: form.querySelector('#heroPhoto').value,
      tagline: form.querySelector('#tagline').value,
      bio: form.querySelector('#bio').value,
      photo: form.querySelector('#photo').value,
      location: form.querySelector('#location').value,
      socials: [...socialsList.querySelectorAll('.social-row')].map(row => ({
        label: row.querySelector('input[name="social-label"]').value.trim(),
        url: row.querySelector('input[name="social-url"]').value.trim(),
      })).filter(s => s.label && s.url),
      whatIDo: [...form.querySelectorAll('input[name="whatIDo"]')].map(el => el.value).filter(Boolean),
      experience: [...form.querySelectorAll('.exp-row')].map(row => ({
        title: row.querySelector('input[name="exp-title"]').value,
        startDate: row.querySelector('input[name="exp-start"]').value,
        endDate: row.querySelector('input[name="exp-present"]').checked ? '' : row.querySelector('input[name="exp-end"]').value,
        location: row.querySelector('input[name="exp-location"]').value,
      })).filter(r => r.title),
      education: [...form.querySelectorAll('.edu-row')].map(row => ({
        title: row.querySelector('input[name="edu-title"]').value,
        startDate: row.querySelector('input[name="edu-start"]').value,
        endDate: row.querySelector('input[name="edu-present"]').checked ? '' : row.querySelector('input[name="edu-end"]').value,
        location: row.querySelector('input[name="edu-location"]').value,
      })).filter(r => r.title),
      tech: [...techTags.querySelectorAll('.tag')].map(el => el.firstChild.textContent.trim()),
      cta: form.querySelector('#cta').value,
    });

    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving…';
    formStatus.style.display = 'none';

    try {
      const res = await fetch('/api/admin/profile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body }),
      });
      const result = await res.json();

      if (!res.ok) {
        formStatus.textContent = result.error || 'Something went wrong';
        formStatus.style.color = 'var(--color-error)';
        formStatus.style.display = 'inline';
        return;
      }

      formStatus.textContent = 'Saved!';
      formStatus.style.color = 'var(--color-accent)';
      formStatus.style.display = 'inline';
    } catch {
      formStatus.textContent = 'Network error';
      formStatus.style.color = 'var(--color-error)';
      formStatus.style.display = 'inline';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save Profile';
    }
  });

  // --- Sync to GitHub ---
  const syncBtn = document.getElementById('sync-gh-btn');
  syncBtn.addEventListener('click', async () => {
    syncBtn.disabled = true;
    syncBtn.textContent = 'Syncing…';
    formStatus.style.display = 'none';

    try {
      const res = await fetch('/api/admin/profile/sync-github', { method: 'POST' });
      const result = await res.json();

      if (!res.ok) {
        formStatus.textContent = result.error || 'GitHub sync failed';
        formStatus.style.color = 'var(--color-error)';
        formStatus.style.display = 'inline';
        return;
      }

      formStatus.textContent = 'Synced to GitHub!';
      formStatus.style.color = 'var(--color-accent)';
      formStatus.style.display = 'inline';
    } catch {
      formStatus.textContent = 'Network error';
      formStatus.style.color = 'var(--color-error)';
      formStatus.style.display = 'inline';
    } finally {
      syncBtn.disabled = false;
      syncBtn.textContent = 'Sync to GitHub';
    }
  });
</script>

<style>
  .field-label {
    display: block;
    font: 500 11px 'IBM Plex Mono', monospace;
    color: var(--color-meta);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .06em;
  }
  .field-input {
    width: 100%;
    height: 36px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 6px;
    padding: 0 10px;
    font: 400 14px 'Space Grotesk', sans-serif;
    color: var(--color-ink);
    outline: none;
    box-sizing: border-box;
    transition: border-color .15s;
  }
  .field-input:focus { border-color: var(--color-accent); }
  .field-textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 6px;
    padding: 10px;
    font: 400 14px 'Space Grotesk', sans-serif;
    color: var(--color-ink);
    outline: none;
    box-sizing: border-box;
    resize: vertical;
    line-height: 1.6;
    transition: border-color .15s;
  }
  .field-textarea:focus { border-color: var(--color-accent); }
  .row-number {
    font: 500 12px 'IBM Plex Mono', monospace;
    color: var(--color-accent);
    width: 22px;
    flex: none;
  }
  .remove-btn {
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border-light);
    background: transparent;
    border-radius: 4px;
    font: 400 16px sans-serif;
    color: var(--color-dim);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    transition: color .15s, border-color .15s;
  }
  .remove-btn:hover { color: var(--color-error); border-color: var(--color-error); }
  .add-btn {
    margin-top: 8px;
    border: 1px dashed var(--color-border);
    background: transparent;
    border-radius: 6px;
    padding: 7px 14px;
    font: 400 12px 'IBM Plex Mono', monospace;
    color: var(--color-dim);
    cursor: pointer;
    transition: border-color .15s, color .15s;
  }
  .add-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 400 12px 'IBM Plex Mono', monospace;
    color: var(--color-ink);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border-light);
    border-radius: 4px;
    padding: 4px 8px;
  }
  .tag-remove {
    border: none;
    background: transparent;
    font: 400 14px sans-serif;
    color: var(--color-dim);
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }
  .tag-remove:hover { color: var(--color-error); }
  .field-label-sm {
    display: block;
    font: 500 9px 'IBM Plex Mono', monospace;
    color: var(--color-placeholder);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: .06em;
  }
  .present-label {
    display: flex;
    align-items: center;
    gap: 4px;
    font: 400 11px 'IBM Plex Mono', monospace;
    color: var(--color-dim);
    cursor: pointer;
  }
  .present-check {
    accent-color: var(--color-accent);
  }
  .section-divider {
    font: 500 11px 'IBM Plex Mono', monospace;
    color: var(--color-accent);
    letter-spacing: .08em;
    text-transform: uppercase;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--color-border-light);
  }
  .submit-btn {
    height: 38px;
    background: #3a7d6c;
    border: none;
    border-radius: 6px;
    padding: 0 24px;
    font: 500 13px 'IBM Plex Mono', monospace;
    color: #fff;
    cursor: pointer;
    transition: background .15s;
  }
