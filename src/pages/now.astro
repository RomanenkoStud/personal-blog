---
import BaseLayout from '../layouts/Base.astro';
import { getPage } from '@/server/repositories/pages';
import { env } from 'cloudflare:workers';
import { PAGE_SLUG } from '@/config';
import { formatMonthYear } from '@/lib/format';

const page = await getPage(env.DB, PAGE_SLUG.NOW);

if (!page) {
  return Astro.redirect('/404');
}

const updatedLabel = formatMonthYear(page.updatedAt);
---

<BaseLayout title="Now" description="What I'm currently working on, learning, and reading.">
  <article class="page-container">

    <div class="px-[92px] pt-11 pb-8 text-center max-sm:px-4 max-sm:pt-7 max-sm:pb-5">
      <div class="font-mono text-[11px] text-dim mb-[18px]">UPDATED {updatedLabel.toUpperCase()}</div>
      <div class="font-heading text-[30px] leading-[1.25] text-ink max-sm:text-2xl">{page.title}</div>
    </div>

    <div class="px-[92px] pb-2 max-sm:px-4">
      {page.body.split('\n\n').map(paragraph => {
        if (paragraph.startsWith('### ')) {
          return <h3 class="font-heading font-semibold text-[17px] text-ink mt-7 mb-3">{paragraph.replace('### ', '')}</h3>;
        }
        if (paragraph.startsWith('## ')) {
          return <h2 class="font-heading font-semibold text-[20px] text-ink mt-8 mb-4">{paragraph.replace('## ', '')}</h2>;
        }
        if (paragraph.startsWith('- ') || paragraph.startsWith('* ')) {
          const items = paragraph.split('\n').filter(l => l.trim());
          return (
            <ul class="mb-4 pl-5 list-disc">
              {items.map(item => {
                const text = item.replace(/^[-*]\s+/, '');
                const parts = text.split(/(\*\*[^*]+\*\*)/g);
                return (
                  <li class="font-heading text-base leading-[1.7] text-body mb-1">
                    {parts.map(part =>
                      part.startsWith('**') && part.endsWith('**')
                        ? <strong class="font-semibold">{part.slice(2, -2)}</strong>
                        : part
                    )}
                  </li>
                );
              })}
            </ul>
          );
        }
        if (paragraph.startsWith('*') && paragraph.endsWith('*') && !paragraph.startsWith('**')) {
          return <p class="font-heading text-sm leading-[1.7] italic text-dim mb-4">{paragraph.slice(1, -1)}</p>;
        }
        return <p class="font-heading text-base leading-[1.7] text-body mb-4">{paragraph}</p>;
      })}
    </div>

  </article>
</BaseLayout>
