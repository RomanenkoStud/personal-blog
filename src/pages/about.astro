---
import BaseLayout from '../layouts/Base.astro';
import { SOCIAL } from '../consts';
---

<BaseLayout title="About" description="Pavlo Romanenko — frontend engineer in Munich. Lean engineering: simple systems, made on purpose.">
  <div style="max-width:780px;margin:0 auto;padding:0">
    <div style="display:flex;gap:26px;padding:34px 30px">

      <!-- Left sidebar -->
      <div style="width:150px;flex:none">
        <div style="width:150px;height:170px;border:1px dashed var(--color-border);background:var(--color-border-light);border-radius:6px;display:flex;align-items:center;justify-content:center;font:400 10px 'IBM Plex Mono',monospace;color:var(--color-placeholder);text-align:center">[ portrait ]</div>
        <div style="margin-top:14px;font:400 11px/1.9 'IBM Plex Mono',monospace;color:var(--color-meta)">
          munich · remote<br />
          <a href={`mailto:${SOCIAL.email}`} class="sidebar-link">→ email</a><br />
          <a href={SOCIAL.github} target="_blank" rel="noopener" class="sidebar-link">→ github</a><br />
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener" class="sidebar-link">→ linkedin</a>
        </div>
      </div>

      <!-- Main content -->
      <div style="flex:1">
        <div style="font:400 26px/1.3 'Space Grotesk',serif;color:var(--color-ink)">Lean engineering: simple systems, made on purpose.</div>

        <!-- bio placeholder bars -->
        <div style="margin-top:14px;height:9px;width:96%;background:var(--color-skeleton);border-radius:3px;margin-bottom:8px"></div>
        <div style="height:9px;width:90%;background:var(--color-skeleton);border-radius:3px"></div>

        <!-- Principles -->
        <div style="margin-top:24px;font:500 10px 'IBM Plex Mono',monospace;letter-spacing:.12em;color:var(--color-placeholder);text-transform:uppercase">principles</div>
        <div style="margin-top:12px;display:flex;flex-direction:column;gap:10px">
          <div style="display:flex;gap:10px;align-items:baseline"><span style="font:500 12px 'IBM Plex Mono',monospace;color:var(--color-indigo)">01</span><span style="font:400 14px 'Space Grotesk',serif;color:var(--color-ink)">Architecture over framework trends</span></div>
          <div style="display:flex;gap:10px;align-items:baseline"><span style="font:500 12px 'IBM Plex Mono',monospace;color:var(--color-indigo)">02</span><span style="font:400 14px 'Space Grotesk',serif;color:var(--color-ink)">Minimalism &amp; pragmatism first</span></div>
          <div style="display:flex;gap:10px;align-items:baseline"><span style="font:500 12px 'IBM Plex Mono',monospace;color:var(--color-indigo)">03</span><span style="font:400 14px 'Space Grotesk',serif;color:var(--color-ink)">AI as a real development partner</span></div>
        </div>

        <!-- Experience -->
        <div style="margin-top:24px;font:500 10px 'IBM Plex Mono',monospace;letter-spacing:.12em;color:var(--color-placeholder);text-transform:uppercase">experience</div>
        <div style="margin-top:12px;border-left:2px solid var(--color-border-light);padding-left:14px;display:flex;flex-direction:column;gap:12px">
          <div>
            <div style="font:400 13px 'Space Grotesk',serif;color:var(--color-ink)">Frontend Engineer · Verisk</div>
            <div style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-dim)">enterprise · 3+ yrs</div>
          </div>
          <div>
            <div style="font:400 13px 'Space Grotesk',serif;color:var(--color-ink)">B.Sc. Computer Engineering · KhNURE</div>
            <div style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-dim)">web · neural networks</div>
          </div>
        </div>

        <!-- CTA -->
        <div style="margin-top:24px;background:var(--color-ink);border-radius:6px;padding:16px 20px;display:flex;align-items:center;gap:16px">
          <div style="font:400 15px 'Space Grotesk',serif;color:var(--color-surface)">Open to senior roles — Munich &amp; remote.</div>
          <a href={`mailto:${SOCIAL.email}`} class="cta-btn" style="margin-left:auto;background:#4f56e8;border-radius:5px;padding:9px 16px;font:500 11px 'IBM Plex Mono',monospace;color:#fff;text-decoration:none">get in touch →</a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .sidebar-link { color: var(--color-meta); text-decoration: none; }
  .sidebar-link:hover { color: var(--color-indigo) !important; }
  .cta-btn:hover { background: #7c81f2 !important; }
</style>
