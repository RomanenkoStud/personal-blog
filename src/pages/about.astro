---
import BaseLayout from '../layouts/Base.astro';
import { SITE_TITLE } from '@/config';
import { getProfile } from '@/server/services/profile';
import { formatDateRange } from '@/lib/format';
import { env } from 'cloudflare:workers';

const data = await getProfile(env.DB);
const emailLink = data?.socials.find(s => s.label.toLowerCase() === 'email');
---

<BaseLayout title="About" description={data?.tagline ? `${SITE_TITLE} — ${data.tagline}` : undefined}>
  <div class="page-container">
    {!data ? (
      <div class="px-16 pt-10 pb-[26px] text-center max-sm:px-4 max-sm:pt-7 max-sm:pb-5">
        <div class="font-heading text-[23px] text-ink">About page not configured yet.</div>
        <p class="mt-3 font-heading text-sm text-dim">Set up your profile in the admin panel.</p>
      </div>
    ) : (
    <div class="flex gap-[26px] p-[34px_30px] max-sm:flex-col max-sm:gap-0 max-sm:p-[24px_16px]">

      <!-- Left sidebar -->
      <div class="w-[150px] shrink-0 max-sm:w-full max-sm:flex max-sm:flex-col max-sm:items-center max-sm:text-center max-sm:pb-5 max-sm:border-b max-sm:border-border-light max-sm:mb-5">
        {data.photo && <img src={data.photo} alt={SITE_TITLE} class="w-[150px] h-[170px] rounded-none object-cover object-[center_top] max-sm:size-[100px] max-sm:rounded-full" />}
        <div class="mt-3.5 font-mono text-[11px] leading-[1.9] text-meta max-sm:mt-3">
          {data.location && <span class="block">{data.location}</span>}
          {data.socials.length > 0 && (
            <div class="flex flex-col max-sm:flex-row max-sm:gap-3 max-sm:mt-1">
              {data.socials.map(s => {
                const isEmail = s.label.toLowerCase() === 'email';
                const href = isEmail ? `mailto:${s.url}` : s.url;
                return (
                  <a href={href} {...(!isEmail && { target: '_blank', rel: 'noopener' })} class="text-meta no-underline hover:text-accent">
                    <span class="max-sm:hidden" aria-hidden="true">→ </span>{s.label}
                  </a>
                );
              })}
            </div>
          )}
        </div>
      </div>

      <!-- Main content -->
      <div class="flex-1 min-w-0">
        <div class="font-display text-[26px] leading-[1.3] text-ink">{data.tagline}</div>

        {data.bio && (
          <p class="mt-3.5 font-heading text-sm leading-[1.7] text-ink">{data.bio}</p>
        )}

        {data.whatIDo.length > 0 && (
          <>
            <div class="mt-6 section-label">what i do</div>
            <div class="mt-3 flex flex-col gap-2.5">
              {data.whatIDo.map((item, i) => (
                <div class="flex gap-2.5 items-baseline">
                  <span class="font-mono font-medium text-xs text-accent">{String(i + 1).padStart(2, '0')}</span>
                  <span class="font-heading text-sm text-ink">{item}</span>
                </div>
              ))}
            </div>
          </>
        )}

        {data.experience.length > 0 && (
          <>
            <div class="mt-6 section-label">experience</div>
            <div class="mt-3 border-l-2 border-border-light pl-3.5 flex flex-col gap-3">
              {data.experience.map(exp => (
                <div>
                  <div class="font-heading text-[13px] text-ink">{exp.title}</div>
                  <div class="font-mono text-[11px] text-dim">
                    {formatDateRange(exp.startDate, exp.endDate)}
                    {exp.location && <span> · {exp.location}</span>}
                  </div>
                </div>
              ))}
            </div>
          </>
        )}

        {data.education.length > 0 && (
          <>
            <div class="mt-6 section-label">education</div>
            <div class="mt-3 border-l-2 border-border-light pl-3.5 flex flex-col gap-3">
              {data.education.map(edu => (
                <div>
                  <div class="font-heading text-[13px] text-ink">{edu.title}</div>
                  <div class="font-mono text-[11px] text-dim">
                    {formatDateRange(edu.startDate, edu.endDate)}
                    {edu.location && <span> · {edu.location}</span>}
                  </div>
                </div>
              ))}
            </div>
          </>
        )}

        {data.tech.length > 0 && (
          <>
            <div class="mt-6 section-label">tech</div>
            <div class="mt-2.5 flex flex-wrap gap-1.5">
              {data.tech.map(t => (
                <span class="font-mono text-[11px] text-meta border border-border-light rounded-none py-[3px] px-2">{t}</span>
              ))}
            </div>
          </>
        )}

        {data.cta && emailLink && (
          <div class="mt-6 bg-ink rounded-none p-[16px_20px] flex items-center gap-4 max-sm:flex-col max-sm:text-center max-sm:gap-3 max-sm:p-4">
            <div class="font-heading text-[15px] text-surface">{data.cta}</div>
            <a href={`mailto:${emailLink.url}`} class="ml-auto bg-accent rounded-none py-[9px] px-4 font-mono font-medium text-[11px] text-on-accent no-underline whitespace-nowrap hover:bg-accent-soft max-sm:ml-0 max-sm:w-full max-sm:text-center max-sm:py-3">get in touch →</a>
          </div>
        )}
      </div>

    </div>
    )}
  </div>
</BaseLayout>
