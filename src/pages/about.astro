---
import BaseLayout from '../layouts/Base.astro';
import { SOCIAL } from '../consts';
import { getPage } from '../lib/api';
import { env } from 'cloudflare:workers';

const page = await getPage(env.DB, 'about');

const defaults = {
  tagline: 'Lean engineering: simple systems, made on purpose.',
  bio: '',
  photo: '/img3.jpg',
  location: 'munich · remote',
  whatIDo: [] as string[],
  experience: [] as { title: string; startDate: string; endDate: string; location: string }[],
  education: [] as { title: string; startDate: string; endDate: string; location: string }[],
  tech: [] as string[],
  cta: '',
};

let data = defaults;
if (page) {
  try {
    data = { ...defaults, ...JSON.parse(page.body) };
  } catch {}
}

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function formatDateRange(startDate: string, endDate: string) {
  if (!startDate) return '';
  const [sy, sm] = startDate.split('-').map(Number);
  const startLabel = `${MONTHS[sm - 1]} ${sy}`;

  const now = new Date();
  const ey = endDate ? Number(endDate.split('-')[0]) : now.getFullYear();
  const em = endDate ? Number(endDate.split('-')[1]) : now.getMonth() + 1;
  const endLabel = endDate ? `${MONTHS[em - 1]} ${ey}` : 'Present';

  let totalMonths = (ey - sy) * 12 + (em - sm) + 1;
  if (totalMonths < 1) totalMonths = 1;
  const years = Math.floor(totalMonths / 12);
  const months = totalMonths % 12;

  const parts: string[] = [];
  if (years > 0) parts.push(`${years} yr${years > 1 ? 's' : ''}`);
  if (months > 0) parts.push(`${months} mo${months > 1 ? 's' : ''}`);
  const duration = parts.join(' ');

  return `${startLabel} – ${endLabel} · ${duration}`;
}
---

<BaseLayout title="About" description={`Pavlo Romanenko — ${data.tagline}`}>
  <div class="page-container">
    <div class="flex gap-[26px] p-[34px_30px] max-sm:flex-col max-sm:gap-0 max-sm:p-[24px_16px]">

      <!-- Left sidebar -->
      <div class="w-[150px] shrink-0 max-sm:w-full max-sm:flex max-sm:flex-col max-sm:items-center max-sm:text-center max-sm:pb-5 max-sm:border-b max-sm:border-border-light max-sm:mb-5">
        <img src={data.photo} alt="Pavlo Romanenko" class="w-[150px] h-[170px] rounded-md object-cover object-[center_top] max-sm:size-[100px] max-sm:rounded-full" />
        <div class="mt-3.5 font-mono text-[11px] leading-[1.9] text-meta max-sm:mt-3">
          <span class="block">{data.location}</span>
          <div class="flex flex-col max-sm:flex-row max-sm:gap-3 max-sm:mt-1">
            <a href={`mailto:${SOCIAL.email}`} class="text-meta no-underline hover:text-indigo"><span class="max-sm:hidden" aria-hidden="true">→ </span>email</a>
            <a href={SOCIAL.github} target="_blank" rel="noopener" class="text-meta no-underline hover:text-indigo"><span class="max-sm:hidden" aria-hidden="true">→ </span>github</a>
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener" class="text-meta no-underline hover:text-indigo"><span class="max-sm:hidden" aria-hidden="true">→ </span>linkedin</a>
          </div>
        </div>
      </div>

      <!-- Main content -->
      <div class="flex-1 min-w-0">
        <div class="font-heading text-[26px] leading-[1.3] text-ink">{data.tagline}</div>

        {data.bio && (
          <p class="mt-3.5 font-heading text-sm leading-[1.7] text-ink">{data.bio}</p>
        )}

        {data.whatIDo.length > 0 && (
          <>
            <div class="mt-6 section-label">what i do</div>
            <div class="mt-3 flex flex-col gap-2.5">
              {data.whatIDo.map((item, i) => (
                <div class="flex gap-2.5 items-baseline">
                  <span class="font-mono font-medium text-xs text-indigo">{String(i + 1).padStart(2, '0')}</span>
                  <span class="font-heading text-sm text-ink">{item}</span>
                </div>
              ))}
            </div>
          </>
        )}

        {data.experience.length > 0 && (
          <>
            <div class="mt-6 section-label">experience</div>
            <div class="mt-3 border-l-2 border-border-light pl-3.5 flex flex-col gap-3">
              {data.experience.map(exp => (
                <div>
                  <div class="font-heading text-[13px] text-ink">{exp.title}</div>
                  <div class="font-mono text-[11px] text-dim">
                    {formatDateRange(exp.startDate, exp.endDate)}
                    {exp.location && <span> · {exp.location}</span>}
                  </div>
                </div>
              ))}
            </div>
          </>
        )}

        {data.education.length > 0 && (
          <>
            <div class="mt-6 section-label">education</div>
            <div class="mt-3 border-l-2 border-border-light pl-3.5 flex flex-col gap-3">
              {data.education.map(edu => (
                <div>
                  <div class="font-heading text-[13px] text-ink">{edu.title}</div>
                  <div class="font-mono text-[11px] text-dim">
                    {formatDateRange(edu.startDate, edu.endDate)}
                    {edu.location && <span> · {edu.location}</span>}
                  </div>
                </div>
              ))}
            </div>
          </>
        )}

        {data.tech.length > 0 && (
          <>
            <div class="mt-6 section-label">tech</div>
            <div class="mt-2.5 flex flex-wrap gap-1.5">
              {data.tech.map(t => (
                <span class="font-mono text-[11px] text-meta border border-border-light rounded-[3px] py-[3px] px-2">{t}</span>
              ))}
            </div>
          </>
        )}

        {data.cta && (
          <div class="mt-6 bg-ink rounded-md p-[16px_20px] flex items-center gap-4 max-sm:flex-col max-sm:text-center max-sm:gap-3 max-sm:p-4">
            <div class="font-heading text-[15px] text-surface">{data.cta}</div>
            <a href={`mailto:${SOCIAL.email}`} class="ml-auto bg-[#4f56e8] rounded-[5px] py-[9px] px-4 font-mono font-medium text-[11px] text-white no-underline whitespace-nowrap hover:bg-periwinkle max-sm:ml-0 max-sm:w-full max-sm:text-center max-sm:py-3">get in touch →</a>
          </div>
        )}
      </div>

    </div>
  </div>
</BaseLayout>
