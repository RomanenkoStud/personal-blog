---
import BaseLayout from '../layouts/Base.astro';
import { SOCIAL } from '../consts';
import { getPage } from '../lib/api';
import { env } from 'cloudflare:workers';

const page = await getPage(env.DB, 'about');

const defaults = {
  tagline: 'Lean engineering: simple systems, made on purpose.',
  bio: '',
  photo: '/img3.jpg',
  location: 'munich · remote',
  whatIDo: [] as string[],
  experience: [] as { title: string; meta: string }[],
  tech: [] as string[],
  cta: '',
};

let data = defaults;
if (page) {
  try {
    data = { ...defaults, ...JSON.parse(page.body) };
  } catch {}
}
---

<BaseLayout title="About" description={`Pavlo Romanenko — ${data.tagline}`}>
  <div style="max-width:780px;margin:0 auto;padding:0">
    <div style="display:flex;gap:26px;padding:34px 30px">

      <!-- Left sidebar -->
      <div style="width:150px;flex:none">
        <img src={data.photo} alt="Pavlo Romanenko" style="width:150px;height:170px;border-radius:6px;object-fit:cover;object-position:center top" />
        <div style="margin-top:14px;font:400 11px/1.9 'IBM Plex Mono',monospace;color:var(--color-meta)">
          {data.location}<br />
          <a href={`mailto:${SOCIAL.email}`} class="sidebar-link">→ email</a><br />
          <a href={SOCIAL.github} target="_blank" rel="noopener" class="sidebar-link">→ github</a><br />
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener" class="sidebar-link">→ linkedin</a>
        </div>
      </div>

      <!-- Main content -->
      <div style="flex:1">
        <div style="font:400 26px/1.3 'Space Grotesk',serif;color:var(--color-ink)">{data.tagline}</div>

        {data.bio && (
          <p style="margin-top:14px;font:400 14px/1.7 'Space Grotesk',serif;color:var(--color-ink)">{data.bio}</p>
        )}

        {data.whatIDo.length > 0 && (
          <>
            <div style="margin-top:24px;font:500 10px 'IBM Plex Mono',monospace;letter-spacing:.12em;color:var(--color-placeholder);text-transform:uppercase">what i do</div>
            <div style="margin-top:12px;display:flex;flex-direction:column;gap:10px">
              {data.whatIDo.map((item, i) => (
                <div style="display:flex;gap:10px;align-items:baseline">
                  <span style="font:500 12px 'IBM Plex Mono',monospace;color:var(--color-indigo)">{String(i + 1).padStart(2, '0')}</span>
                  <span style="font:400 14px 'Space Grotesk',serif;color:var(--color-ink)">{item}</span>
                </div>
              ))}
            </div>
          </>
        )}

        {data.experience.length > 0 && (
          <>
            <div style="margin-top:24px;font:500 10px 'IBM Plex Mono',monospace;letter-spacing:.12em;color:var(--color-placeholder);text-transform:uppercase">experience</div>
            <div style="margin-top:12px;border-left:2px solid var(--color-border-light);padding-left:14px;display:flex;flex-direction:column;gap:12px">
              {data.experience.map(exp => (
                <div>
                  <div style="font:400 13px 'Space Grotesk',serif;color:var(--color-ink)">{exp.title}</div>
                  <div style="font:400 11px 'IBM Plex Mono',monospace;color:var(--color-dim)">{exp.meta}</div>
                </div>
              ))}
            </div>
          </>
        )}

        {data.tech.length > 0 && (
          <>
            <div style="margin-top:24px;font:500 10px 'IBM Plex Mono',monospace;letter-spacing:.12em;color:var(--color-placeholder);text-transform:uppercase">tech</div>
            <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px">
              {data.tech.map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </>
        )}

        {data.cta && (
          <div style="margin-top:24px;background:var(--color-ink);border-radius:6px;padding:16px 20px;display:flex;align-items:center;gap:16px">
            <div style="font:400 15px 'Space Grotesk',serif;color:var(--color-surface)">{data.cta}</div>
            <a href={`mailto:${SOCIAL.email}`} class="cta-btn" style="margin-left:auto;background:#4f56e8;border-radius:5px;padding:9px 16px;font:500 11px 'IBM Plex Mono',monospace;color:#fff;text-decoration:none">get in touch →</a>
          </div>
        )}
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .sidebar-link { color: var(--color-meta); text-decoration: none; }
  .sidebar-link:hover { color: var(--color-indigo) !important; }
  .cta-btn:hover { background: #7c81f2 !important; }
  .tech-tag { font: 400 11px 'IBM Plex Mono', monospace; color: var(--color-meta); border: 1px solid var(--color-border-light); border-radius: 3px; padding: 3px 8px; }
</style>
