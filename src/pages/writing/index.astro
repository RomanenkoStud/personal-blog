---
import BaseLayout from '../../layouts/Base.astro';
import { getPostsList, getAreas } from '../../lib/api';
import { parseListParams, buildListHref } from '../../lib/query';
import { env } from 'cloudflare:workers';

const params = parseListParams(Astro.url, { filterKeys: ['area'] });

const [result, areas] = await Promise.all([
  getPostsList(env.DB, params),
  getAreas(env.DB),
]);

const { items: posts, totalPages, page: currentPage } = result;
const activeArea = params.filters.area;

const postsByYear = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = new Date(post.publishedAt).getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

const href = (overrides?: Parameters<typeof buildListHref>[2]) =>
  buildListHref('/writing', params, overrides);
---

<BaseLayout title="Writing" description="Articles on architecture, tools, and home-lab tinkering.">
  <div class="page-container px-[26px] max-sm:px-4">

    <!-- Title + filter chips -->
    <div class="pt-[30px] pb-[18px]">
      <div class="font-heading text-[26px] text-ink">Everything I've written</div>
      <div class="flex gap-2 mt-4 flex-wrap">
        <a href={href({ page: 1, filters: {} })} class:list={['chip', { active: !activeArea }]}>all</a>
        {areas.map(({ area, count }) => (
          <a href={href({ page: 1, filters: { area } })} class:list={['chip', { active: activeArea === area }]}>
            {area}<span class="chip-count">{count}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Posts grouped by year -->
    {years.map(year => (
      <div>
        <div class="pt-4 pb-2">
          <span class="font-mono font-medium text-[10px] tracking-[.14em] text-indigo">{year}</span>
        </div>
        <div>
          {postsByYear[year].map(post => (
            <a href={`/writing/${post.slug}`} class="group flex items-baseline gap-[18px] py-[13px] border-t border-border-light no-underline text-inherit hover:text-inherit max-sm:flex-col max-sm:gap-1">
              <span class="w-[58px] font-mono text-[11px] text-placeholder shrink-0">{post.publishedAt.slice(0, 7)}</span>
              <span class="flex-1 font-heading text-[15px] text-ink group-hover:text-indigo">{post.featured && <span class="text-indigo mr-1.5" title="Featured">★</span>}{post.title}</span>
              <span class="font-mono text-[10px] text-indigo shrink-0">{post.area}</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    {posts.length === 0 && (
      <div class="py-10 text-center font-mono text-sm text-placeholder">
        No posts found.
      </div>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav class="flex items-center justify-center gap-1 pt-7">
        {currentPage > 1 ? (
          <a href={href({ page: currentPage - 1 })} class="page-link">&larr; prev</a>
        ) : (
          <span class="page-link disabled">&larr; prev</span>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
          <a href={href({ page: p })} class:list={['page-link', { current: p === currentPage }]}>{p}</a>
        ))}
        {currentPage < totalPages ? (
          <a href={href({ page: currentPage + 1 })} class="page-link">next &rarr;</a>
        ) : (
          <span class="page-link disabled">next &rarr;</span>
        )}
      </nav>
    )}

    <div class="h-6"></div>
  </div>
</BaseLayout>
