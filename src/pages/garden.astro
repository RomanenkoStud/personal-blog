---
import BaseLayout from '../layouts/Base.astro';
import { getPosts } from '../lib/api';
import { env } from 'cloudflare:workers';

const posts = await getPosts(env.DB);

const byArea = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  if (!acc[post.area]) acc[post.area] = [];
  acc[post.area].push(post);
  return acc;
}, {});

const areas = Object.entries(byArea).sort((a, b) => b[1].length - a[1].length);
const maxNotes = Math.max(...areas.map(([, p]) => p.length), 1);
const recentPosts = posts.slice(0, 4);
---

<BaseLayout title="Garden" description="A digital garden of notes on the systems I build and the lessons they teach.">
  <div class="page-container">

    <div class="px-16 pt-10 pb-[26px] text-center max-sm:px-4 max-sm:pt-7 max-sm:pb-5">
      <div class="font-heading text-[23px] leading-[1.4] text-ink max-w-[440px] mx-auto max-sm:text-[20px]">A digital garden of notes on the systems I build and the lessons they teach.</div>
    </div>

    <div class="px-10 pb-3.5 flex flex-col gap-0.5 max-sm:px-4">
      {areas.map(([area, areaPosts]) => (
        <div class="flex items-center gap-3.5 py-[15px] px-1.5 border-t border-border-light">
          <span class="w-[130px] font-heading text-[15px] text-ink capitalize">{area}</span>
          <div class="flex-1 h-2 bg-skeleton rounded-[3px]" style={`max-width:${Math.round((areaPosts.length / maxNotes) * 280)}px`}></div>
          <span class="ml-auto font-mono text-[11px] text-placeholder">{areaPosts.length} {areaPosts.length === 1 ? 'note' : 'notes'}</span>
        </div>
      ))}
    </div>

    <div class="px-10 pt-5 pb-[30px] max-sm:px-4 max-sm:pt-4 max-sm:pb-6">
      <div class="section-label mb-2.5">recently tended</div>
      {recentPosts.map(post => (
        <a href={`/writing/${post.slug}`} class="group flex items-baseline gap-3 py-[9px] no-underline text-inherit hover:text-inherit">
          <span class="font-heading text-sm text-ink group-hover:text-indigo">{post.title}</span>
          <span class="ml-auto font-mono text-[10px] text-indigo shrink-0">↔ {Math.floor(Math.random() * 4) + 2} links</span>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
