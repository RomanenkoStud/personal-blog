---
import BaseLayout from '../layouts/Base.astro';
import { getPosts } from '../lib/api';
import { env } from 'cloudflare:workers';

const posts = await getPosts(env.DB);

const byArea = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  if (!acc[post.area]) acc[post.area] = [];
  acc[post.area].push(post);
  return acc;
}, {});

const areas = Object.entries(byArea).sort((a, b) => b[1].length - a[1].length);
const maxNotes = Math.max(...areas.map(([, p]) => p.length), 1);
const recentPosts = posts.slice(0, 4);
---

<BaseLayout title="Garden" description="A digital garden of notes on the systems I build and the lessons they teach.">
  <div style="max-width:780px;margin:0 auto;padding:0">

    <!-- Centered tagline -->
    <div style="padding:40px 64px 26px;text-align:center">
      <div style="font:400 23px/1.4 'Space Grotesk',serif;color:var(--color-ink);max-width:440px;margin:0 auto">A digital garden of notes on the systems I build and the lessons they teach.</div>
    </div>

    <!-- Topic rows -->
    <div style="padding:0 40px 14px;display:flex;flex-direction:column;gap:2px">
      {areas.map(([area, areaPosts]) => (
        <div style="display:flex;align-items:center;gap:14px;padding:15px 6px;border-top:1px solid var(--color-border-light)">
          <span style="width:130px;font:400 15px 'Space Grotesk',serif;color:var(--color-ink);text-transform:capitalize">{area}</span>
          <div style={`flex:1;height:8px;background:var(--color-skeleton);border-radius:3px;max-width:${Math.round((areaPosts.length / maxNotes) * 280)}px`}></div>
          <span style="margin-left:auto;font:400 11px 'IBM Plex Mono',monospace;color:var(--color-placeholder)">{areaPosts.length} {areaPosts.length === 1 ? 'note' : 'notes'}</span>
        </div>
      ))}
    </div>

    <!-- Recently tended -->
    <div style="padding:20px 40px 30px">
      <div style="font:500 10px 'IBM Plex Mono',monospace;letter-spacing:.14em;color:var(--color-placeholder);text-transform:uppercase;margin-bottom:10px">recently tended</div>
      {recentPosts.map(post => (
        <a href={`/writing/${post.slug}`} class="garden-row" style="display:flex;align-items:baseline;gap:12px;padding:9px 0;text-decoration:none;color:inherit">
          <span class="garden-title" style="font:400 14px 'Space Grotesk',serif;color:var(--color-ink)">{post.title}</span>
          <span style="margin-left:auto;font:400 10px 'IBM Plex Mono',monospace;color:var(--color-indigo);flex-shrink:0">↔ {Math.floor(Math.random() * 4) + 2} links</span>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .garden-row:hover .garden-title { color: var(--color-indigo) !important; }
</style>
