# Astro Blog
STRAPI_URL=http://strapi:1337
STRAPI_TOKEN=your-strapi-api-token-here
USE_MOCK_DATA=false

# PostgreSQL
DB_USER=strapi
DB_PASSWORD=change-me-to-a-secure-password

# Strapi Secrets (generate with: openssl rand -base64 32)
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=generate-a-random-salt
STRAPI_ADMIN_JWT_SECRET=generate-a-random-secret
STRAPI_JWT_SECRET=generate-a-random-secret

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
