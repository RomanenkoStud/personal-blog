{
  "name": "personal-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev",
    "deploy": "astro build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply blog-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply blog-db --remote",
    "db:seed:local": "wrangler d1 execute blog-db --local --file=seed.sql",
    "db:seed:remote": "wrangler d1 execute blog-db --remote --file=seed.sql",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@stackblitz/sdk": "^1.11.0",
    "astro": "^6.4.7",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.4.2",
    "lit": "^3.3.3",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "drizzle-kit": "^1.0.0-rc.3",
    "tailwindcss": "^4.3.1",
    "wrangler": "^4.103.0"
  }
}
